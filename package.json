{
  "name": "sensai-content-generation",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev:infra": "docker compose -f docker-compose.dev.yml up -d",
    "dev:infra:down": "docker compose -f docker-compose.dev.yml down",
    "dev:api": "pnpm --filter @sensai/api start:dev",
    "dev:web": "pnpm --filter @sensai/web dev",
    "db:generate": "pnpm --filter @sensai/api db:generate",
    "db:migrate": "pnpm --filter @sensai/api db:migrate",
    "db:seed": "pnpm --filter @sensai/api db:seed",
    "test": "pnpm -r --if-present test",
    "smoke:plan-06": "apps/api/node_modules/.bin/tsx --tsconfig apps/api/tsconfig.json scripts/smoke-plan-06.ts",
    "smoke:plan-07": "apps/api/node_modules/.bin/tsx --tsconfig apps/api/tsconfig.json scripts/smoke-plan-07.ts",
    "smoke:plan-09": "apps/api/node_modules/.bin/tsx --tsconfig apps/api/tsconfig.json scripts/smoke-plan-09.ts",
    "smoke:plan-10": "apps/api/node_modules/.bin/tsx --tsconfig apps/api/tsconfig.json scripts/smoke-plan-10.ts"
  },
  "engines": {
    "node": ">=20.11",
    "pnpm": ">=9.0"
  },
  "packageManager": "pnpm@9.15.0"
}
